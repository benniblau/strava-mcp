# =============================================================================
# STRAVA API CREDENTIALS
# =============================================================================
# Get these from https://www.strava.com/settings/api

STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# OAuth tokens — auto-updated by strava_downloader.py after each run.
# To get your initial refresh token:
#   1. Visit: https://www.strava.com/oauth/authorize?client_id=YOUR_CLIENT_ID&redirect_uri=http://localhost&response_type=code&scope=activity:read_all,profile:read_all
#   2. Authorize the app, copy the `code=` value from the redirect URL
#   3. Exchange for tokens:
#      curl -X POST https://www.strava.com/oauth/token \
#        -d client_id=YOUR_CLIENT_ID \
#        -d client_secret=YOUR_CLIENT_SECRET \
#        -d code=AUTHORIZATION_CODE \
#        -d grant_type=authorization_code
#   4. Copy access_token, refresh_token, and expires_at from the response below.
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_EXPIRES_AT=0

# =============================================================================
# SYNC SETTINGS
# =============================================================================

STRAVA_DB_PATH=./strava_activities.db

# Optional: earliest date to sync activities from (YYYY-MM-DD).
# If not set, defaults to 2 years back from today.
STRAVA_START_DATE=2020-01-01

# =============================================================================
# MCP SERVER HTTP TRANSPORT
# =============================================================================

# Set to "http" for remote MCP clients (default: "stdio" for Claude Desktop)
STRAVA_MCP_TRANSPORT=http

# Required when STRAVA_MCP_TRANSPORT=http.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
STRAVA_MCP_AUTH_TOKEN=

STRAVA_MCP_HTTP_HOST=0.0.0.0
STRAVA_MCP_HTTP_PORT=8080
